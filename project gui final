-- ========== HITBOX SCRIPT (ASLI) ==========
local PlayersHitbox = game:GetService("Players")
local LocalPlayerHitbox = PlayersHitbox.LocalPlayer
local RunServiceHitbox = game:GetService("RunService")

local extremeHitboxActive = false
local hitboxSize = 35
local originalSizes = {}
local updateInterval = 0.3
local timer = 0
local renderHitboxConn = nil

local bodyParts = {"HumanoidRootPart", "Head", "UpperTorso", "LowerTorso", "LeftArm", "RightArm", "LeftLeg", "RightLeg"}

local function isSurvivorHitbox(player) return player ~= LocalPlayerHitbox and player.Team and player.Team.Name == "Survivors" end
local function saveOriginalSizeHitbox(part, player) local key = player .. "_" .. part.Name if not originalSizes[key] then originalSizes[key] = {Size = part.Size, CanCollide = part.CanCollide} end end
local function expandPartHitbox(part, player) if not part or not part.Parent then return end saveOriginalSizeHitbox(part, player) pcall(function() part.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize) part.CanCollide = false end) end
local function resetPartHitbox(part, player) if not part then return end local key = player .. "_" .. part.Name local original = originalSizes[key] if original then pcall(function() part.Size = original.Size part.CanCollide = original.CanCollide end) originalSizes[key] = nil end end

local function expandPlayerHitbox(player)
    if not isSurvivorHitbox(player) then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end
    for _, partName in pairs(bodyParts) do local part = char:FindFirstChild(partName) if part then expandPartHitbox(part, player) end end
end

local function resetPlayerHitbox(player)
    if not player then return end
    local char = player.Character
    if not char then return end
    for _, partName in pairs(bodyParts) do local part = char:FindFirstChild(partName) if part then resetPartHitbox(part, player) end end
end

local function resetAllHitboxes()
    for key, _ in pairs(originalSizes) do local playerName = string.match(key, "([^_]+)") local plr = PlayersHitbox:FindFirstChild(playerName) if plr then resetPlayerHitbox(plr) end end
    originalSizes = {}
end

local function updateAllHitboxes()
    for _, player in pairs(PlayersHitbox:GetPlayers()) do if isSurvivorHitbox(player) then expandPlayerHitbox(player) end end
end

local function setupHitboxRender()
    if renderHitboxConn then renderHitboxConn:Disconnect() end
    renderHitboxConn = RunServiceHitbox.RenderStepped:Connect(function(dt)
        if not extremeHitboxActive then return end
        timer = timer + dt
        if timer >= updateInterval then timer = 0 updateAllHitboxes() end
    end)
end

local function startExtremeHitbox(size)
    if size then hitboxSize = size end
    if extremeHitboxActive then return end
    extremeHitboxActive = true
    updateAllHitboxes()
    setupHitboxRender()
    PlayersHitbox.PlayerAdded:Connect(function(player) player.CharacterAdded:Connect(function() task.wait(0.2) if extremeHitboxActive and isSurvivorHitbox(player) then expandPlayerHitbox(player) end end) end)
    for _, player in pairs(PlayersHitbox:GetPlayers()) do if player ~= LocalPlayerHitbox then player.CharacterAdded:Connect(function() task.wait(0.2) if extremeHitboxActive and isSurvivorHitbox(player) then expandPlayerHitbox(player) end end) end end
end

local function stopExtremeHitbox()
    if not extremeHitboxActive then return end
    extremeHitboxActive = false
    if renderHitboxConn then renderHitboxConn:Disconnect() renderHitboxConn = nil end
    resetAllHitboxes()
    timer = 0
end
