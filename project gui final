-- ========== MOONWALK SCRIPT (ASLI) ==========
local PlayersMoon = game:GetService("Players")
local LocalPlayerMoon = PlayersMoon.LocalPlayer
local RunServiceMoon = game:GetService("RunService")
local UISMoon = game:GetService("UserInputService")
local CoreGuiMoon = game:GetService("CoreGui")

local moonwalkChar, moonwalkHumanoid, moonwalkRootPart = nil, nil, nil
local currentGuiMoon, moonwalkButton = nil, nil
local moonwalkActive = false
local turningLeft, turningRight = false, false
local baseYaw, currentYaw = 0, 0
local maxTurn, turnSpeed, returnSpeed = 40, 850, 800
local moonwalkConnections, moonwalkButtonConnections = {}, {}
local lastCharCheck, charValid = 0, false
local moonwalkSystemActive = false

local function updateMoonwalkCharacterRefs(newChar)
    moonwalkChar = newChar or LocalPlayerMoon.Character
    if not moonwalkChar then charValid = false return false end
    moonwalkHumanoid = moonwalkChar:FindFirstChild("Humanoid")
    moonwalkRootPart = moonwalkChar:FindFirstChild("HumanoidRootPart")
    charValid = (moonwalkHumanoid and moonwalkRootPart and moonwalkRootPart.Parent ~= nil)
    return charValid
end

local function getYaw(cf) local _, y, _ = cf:ToEulerAnglesYXZ() return math.deg(y) end
local function setYaw(cf, yaw) return CFrame.new(cf.Position) * CFrame.Angles(0, math.rad(yaw), 0) end

local function clearMoonwalkButtonEvents()
    for _, conn in pairs(moonwalkButtonConnections) do pcall(function() conn:Disconnect() end) end
    moonwalkButtonConnections = {}
end

local function enableMoonwalk()
    if not charValid then if not updateMoonwalkCharacterRefs() then return end end
    if not moonwalkRootPart or not moonwalkHumanoid then return end
    if moonwalkActive then return end
    moonwalkActive = true
    moonwalkHumanoid.AutoRotate = false
    baseYaw = getYaw(moonwalkRootPart.CFrame)
    currentYaw = baseYaw
    if moonwalkButton then pcall(function() moonwalkButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255) end) end
end

local function disableMoonwalk()
    if not moonwalkActive then return end
    moonwalkActive = false
    if charValid and moonwalkHumanoid then moonwalkHumanoid.AutoRotate = true end
    if moonwalkButton then pcall(function() moonwalkButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end) end
    turningLeft, turningRight = false, false
end

local function destroyMoonwalkGUI()
    if currentGuiMoon then pcall(function() currentGuiMoon:Destroy() end) currentGuiMoon = nil end
    moonwalkButton = nil
end

local function createMoonwalkGUI()
    if currentGuiMoon then destroyMoonwalkGUI() end
    clearMoonwalkButtonEvents()
    local gui = Instance.new("ScreenGui")
    gui.Name = "MoonwalkController"
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.Parent = CoreGuiMoon
    currentGuiMoon = gui
    moonwalkButton = Instance.new("TextButton")
    moonwalkButton.Size = UDim2.new(0, 50, 0, 50)
    moonwalkButton.Position = UDim2.new(1, -60, 1, -120)
    moonwalkButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    moonwalkButton.Text = "R"
    moonwalkButton.TextColor3 = Color3.new(1, 1, 1)
    moonwalkButton.TextScaled = true
    moonwalkButton.BorderSizePixel = 0
    moonwalkButton.Parent = gui
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = moonwalkButton
    local mouseDownConn = moonwalkButton.MouseButton1Down:Connect(enableMoonwalk)
    table.insert(moonwalkButtonConnections, mouseDownConn)
    local mouseUpConn = moonwalkButton.MouseButton1Up:Connect(disableMoonwalk)
    table.insert(moonwalkButtonConnections, mouseUpConn)
    local touchBeganConn = moonwalkButton.TouchBegan:Connect(enableMoonwalk)
    table.insert(moonwalkButtonConnections, touchBeganConn)
    local touchEndedConn = moonwalkButton.TouchEnded:Connect(disableMoonwalk)
    table.insert(moonwalkButtonConnections, touchEndedConn)
end

local function startMoonwalkSystem()
    if moonwalkSystemActive then return end
    moonwalkSystemActive = true
    clearMoonwalkButtonEvents()
    moonwalkConnections = {}
    local touchMovedConn = UISMoon.TouchMoved:Connect(function(input)
        if not moonwalkActive then return end
        if math.abs(input.Delta.X) > 3 then
            if input.Delta.X > 0 then turningRight, turningLeft = true, false
            else turningLeft, turningRight = true, false end
        end
    end)
    table.insert(moonwalkConnections, touchMovedConn)
    local touchEndedConn = UISMoon.TouchEnded:Connect(function() turningLeft, turningRight = false, false end)
    table.insert(moonwalkConnections, touchEndedConn)
    local inputBeganConn = UISMoon.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.R then enableMoonwalk() end
    end)
    table.insert(moonwalkConnections, inputBeganConn)
    local inputEndedConn = UISMoon.InputEnded:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.R then disableMoonwalk() end
    end)
    table.insert(moonwalkConnections, inputEndedConn)
    local renderConn = RunServiceMoon.RenderStepped:Connect(function(dt)
        if not moonwalkActive then return end
        local now = tick()
        if now - lastCharCheck >= 0.5 then
            lastCharCheck = now
            if not charValid then if not updateMoonwalkCharacterRefs() then return end end
        end
        if not moonwalkRootPart or not moonwalkHumanoid or not moonwalkRootPart.Parent then charValid = false return end
        if turningLeft then currentYaw = math.clamp(currentYaw - turnSpeed * dt, baseYaw - maxTurn, baseYaw + maxTurn)
        elseif turningRight then currentYaw = math.clamp(currentYaw + turnSpeed * dt, baseYaw - maxTurn, baseYaw + maxTurn)
        else
            if currentYaw < baseYaw then currentYaw = math.min(currentYaw + returnSpeed * dt, baseYaw)
            elseif currentYaw > baseYaw then currentYaw = math.max(currentYaw - returnSpeed * dt, baseYaw) end
        end
        if moonwalkRootPart and moonwalkRootPart.Parent then
            moonwalkRootPart.CFrame = setYaw(CFrame.new(moonwalkRootPart.CFrame.Position), currentYaw)
        end
    end)
    table.insert(moonwalkConnections, renderConn)
    local charAddedConn = LocalPlayerMoon.CharacterAdded:Connect(function(newChar)
        task.wait(0.2)
        updateMoonwalkCharacterRefs(newChar)
        if moonwalkActive then disableMoonwalk() task.wait(0.1) enableMoonwalk() end
    end)
    table.insert(moonwalkConnections, charAddedConn)
    updateMoonwalkCharacterRefs()
    createMoonwalkGUI()
end

local function stopMoonwalkSystem()
    moonwalkSystemActive = false
    destroyMoonwalkGUI()
    if moonwalkActive then disableMoonwalk() end
    for _, conn in ipairs(moonwalkConnections) do pcall(function() conn:Disconnect() end) end
    moonwalkConnections = {}
    clearMoonwalkButtonEvents()
end
