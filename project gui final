-- ========== NO CLIP SCRIPT (ASLI) ==========
local PlayersNoclip = game:GetService("Players")
local LocalPlayerNoclip = PlayersNoclip.LocalPlayer
local RunServiceNoclip = game:GetService("RunService")

local noclipActive = false
local noclipConn = nil
local originalCanCollide = {}

local function saveOriginalCollision(character)
    if not character then return end
    originalCanCollide = {}
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.CanCollide then
            originalCanCollide[part] = part.CanCollide
        end
    end
end

local function restoreOriginalCollision(character)
    for part, canCollide in pairs(originalCanCollide) do
        if part and part.Parent then
            pcall(function() part.CanCollide = canCollide end)
        end
    end
    originalCanCollide = {}
end

local function setNoclip(state)
    local character = LocalPlayerNoclip.Character
    if not character then return end
    if state then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                if not originalCanCollide[part] then
                    originalCanCollide[part] = part.CanCollide
                end
                part.CanCollide = false
            end
        end
    else
        for part, canCollide in pairs(originalCanCollide) do
            if part and part.Parent then
                part.CanCollide = canCollide
            end
        end
        originalCanCollide = {}
    end
end

local function startNoclip()
    if noclipActive then return end
    noclipActive = true
    local character = LocalPlayerNoclip.Character
    if character then
        saveOriginalCollision(character)
        setNoclip(true)
    end
    local characterAddedConn = LocalPlayerNoclip.CharacterAdded:Connect(function(newChar)
        task.wait(0.1)
        if noclipActive then
            saveOriginalCollision(newChar)
            setNoclip(true)
        end
    end)
    noclipConn = RunServiceNoclip.RenderStepped:Connect(function()
        if not noclipActive then return end
        local char = LocalPlayerNoclip.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide == true then
                part.CanCollide = false
            end
        end
    end)
    noclipConn.CharacterAdded = characterAddedConn
end

local function stopNoclip()
    if not noclipActive then return end
    noclipActive = false
    if noclipConn then
        if noclipConn.CharacterAdded then
            pcall(function() noclipConn.CharacterAdded:Disconnect() end)
        end
        noclipConn:Disconnect()
        noclipConn = nil
    end
    restoreOriginalCollision(LocalPlayerNoclip.Character)
end
