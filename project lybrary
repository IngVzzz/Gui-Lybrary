-- ===== MOBILEUI LIBRARY v1.0 =====
-- Lightweight UI framework for Roblox mobile exploits
-- Size: ~6 KB, 50-60 FPS on mobile

local MobileUI = {}
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Private variables
local _elements = {}
local _tabs = {}
local _currentTab = nil
local _currentTabIndex = nil
local _visible = false
local _screen = {X = 0, Y = 0}
local _contentY = 0
local _tabButtons = {}
local _tabTexts = {}

-- Update screen size
local function updateScreen()
    local cam = workspace.CurrentCamera
    _screen.X = cam.ViewportSize.X
    _screen.Y = cam.ViewportSize.Y
end
updateScreen()

RunService.RenderStepped:Connect(updateScreen)

