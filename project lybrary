-- ===== UPDATE POSITIONS =====
local function updatePositions()
    _components.MainFrame.Size = Vector2.new(_screen.X - 100, _screen.Y - 100)
    _components.MainFrame.Position = Vector2.new(50, 50)
    
    _components.FrameBorder.Size = Vector2.new(_screen.X - 100, _screen.Y - 100)
    _components.FrameBorder.Position = Vector2.new(50, 50)
    
    _components.TitleBar.Size = Vector2.new(_screen.X - 100, 40)
    _components.TitleBar.Position = Vector2.new(50, 50)
    
    _components.TitleText.Position = Vector2.new(70, 58)
    
    _components.CloseBtn.Position = Vector2.new(_screen.X - 110, 55)
    _components.CloseIcon.Position = Vector2.new(_screen.X - 98, 60)
    
    _components.LeftPanel.Size = Vector2.new(150, _screen.Y - 140)
    _components.LeftPanel.Position = Vector2.new(50, 90)
    
    _components.RightPanel.Size = Vector2.new(_screen.X - 250, _screen.Y - 140)
    _components.RightPanel.Position = Vector2.new(200, 90)
    
    -- Update tab buttons positions
    for i, btn in pairs(_tabButtons) do
        local yPos = 100 + (i - 1) * 50
        btn.Position = Vector2.new(55, yPos)
        if _tabTexts[i] then
            _tabTexts[i].Position = Vector2.new(90, yPos + 13)
        end
    end
end

-- ===== SHOW/HIDE GUI =====
local function showGUI()
    _visible = true
    _components.MainFrame.Visible = true
    _components.FrameBorder.Visible = true
    _components.TitleBar.Visible = true
    _components.TitleText.Visible = true
    _components.CloseBtn.Visible = true
    _components.CloseIcon.Visible = true
    _components.LeftPanel.Visible = true
    _components.RightPanel.Visible = true
    
    for _, btn in pairs(_tabButtons) do
        btn.Visible = true
    end
    for _, txt in pairs(_tabTexts) do
        txt.Visible = true
    end
    
    _contentY = 110
    updatePositions()
end

local function hideGUI()
    _visible = false
    _components.MainFrame.Visible = false
    _components.FrameBorder.Visible = false
    _components.TitleBar.Visible = false
    _components.TitleText.Visible = false
    _components.CloseBtn.Visible = false
    _components.CloseIcon.Visible = false
    _components.LeftPanel.Visible = false
    _components.RightPanel.Visible = false
    
    for _, btn in pairs(_tabButtons) do
        btn.Visible = false
    end
    for _, txt in pairs(_tabTexts) do
        txt.Visible = false
    end
    
    -- Hide all elements
    for _, element in pairs(_elements) do
        if element.Main then element.Main.Visible = false end
        if element.Label then element.Label.Visible = false end
        if element.Handle then element.Handle.Visible = false end
        if element.Fill then element.Fill.Visible = false end
    end
end

-- ===== SETUP TOGGLE BUTTON =====
local function setupToggleButton()
    _components.ToggleButton.InputBegan = function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            _components.ToggleButton.Color = 0xFF444444
            task.wait(0.05)
            _components.ToggleButton.Color = 0xFF222222
            
            if _visible then
                hideGUI()
            else
                showGUI()
            end
        end
    end
    
    _components.CloseBtn.InputBegan = function(input)
        if input.UserInputType == Enum.UserInputType.Touch and _visible then
            _components.CloseBtn.Color = 0xFF555555
            task.wait(0.05)
            _components.CloseBtn.Color = 0xFF333333
            hideGUI()
        end
    end
end

-- ===== PUBLIC METHODS =====

-- Create Window (inisialisasi)
function MobileUI:CreateWindow(title)
    createObjects()
    setupToggleButton()
    _components.TitleText.Text = title or "SUXANOX UI"
    return self
end

-- Create Tab
function MobileUI:CreateTab(name)
    local index = #_tabButtons + 1
    local yPos = 100 + (index - 1) * 50
    
    local tabBtn = Drawing.new("Square")
    tabBtn.Filled = true
    tabBtn.Color = 0xFF1A1A2E
    tabBtn.Size = Vector2.new(140, 40)
    tabBtn.Position = Vector2.new(55, yPos)
    tabBtn.Visible = false
    tabBtn.Thickness = 0
    
    local tabText = Drawing.new("Text")
    tabText.Text = name
    tabText.Size = 12
    tabText.Color = 0xFFFFFFFF
    tabText.Position = Vector2.new(90, yPos + 13)
    tabText.Visible = false
    
    _tabButtons[index] = tabBtn
    _tabTexts[index] = tabText
    _tabs[index] = {
        Name = name,
        Button = tabBtn,
        Text = tabText,
        Elements = {}
    }
    
    -- Tab click handler
    tabBtn.InputBegan = function(input)
        if input.UserInputType == Enum.UserInputType.Touch and _visible then
            -- Reset previous tab
            if _currentTabIndex then
                for _, element in pairs(_tabs[_currentTabIndex].Elements) do
                    if element.Main then element.Main.Visible = false end
                    if element.Label then element.Label.Visible = false end
                    if element.Handle then element.Handle.Visible = false end
                    if element.Fill then element.Fill.Visible = false end
                    if element.Selected then element.Selected.Visible = false end
                    if element.Arrow then element.Arrow.Visible = false end
                end
                _tabButtons[_currentTabIndex].Color = 0xFF1A1A2E
                _tabTexts[_currentTabIndex].Color = 0xFFFFFFFF
            end
            
            -- Activate new tab
            _currentTabIndex = index
            _currentTab = _tabs[index]
            _tabButtons[index].Color = 0xFF3333AA
            _tabTexts[index].Color = 0xFFFFFFFF
            
            -- Show elements
            for _, element in pairs(_currentTab.Elements) do
                if element.Main then element.Main.Visible = true end
                if element.Label then element.Label.Visible = true end
                if element.Handle then element.Handle.Visible = true end
                if element.Fill then element.Fill.Visible = true end
                if element.Selected then element.Selected.Visible = true end
                if element.Arrow then element.Arrow.Visible = true end
            end
        end
    end
    
    -- Auto select first tab
    if index == 1 then
        tabBtn.Color = 0xFF3333AA
        _currentTabIndex = 1
        _currentTab = _tabs[1]
    end
    
    return index
end

-- Internal: get current content Y position
function MobileUI:GetContentY()
    return _contentY
end

-- Internal: increment content Y
function MobileUI:IncContentY(amount)
    _contentY = _contentY + amount
end

-- Internal: reset content Y
function MobileUI:ResetContentY()
    _contentY = 110
end

-- Internal: check if visible
function MobileUI:IsVisible()
    return _visible
end

-- Get screen width
function MobileUI:ScreenWidth()
    return _screen.X
end

-- Get screen height
function MobileUI:ScreenHeight()
    return _screen.Y
end

-- Register element to tab
function MobileUI:RegisterElement(tabIndex, element)
    if _tabs[tabIndex] then
        table.insert(_tabs[tabIndex].Elements, element)
    end
end

return MobileUI
