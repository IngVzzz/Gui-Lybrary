local DemoxLib = {}

-- Variabel global
local gui = nil
local mainFrame = nil
local leftPanel = nil
local rightPanel = nil
local scrollFrame = nil
local toggleBtn = nil
local isOpen = false
local allTabs = {}

-- Warna
local colors = {
    bg = Color3.fromRGB(20, 20, 30),
    left = Color3.fromRGB(25, 25, 38),
    tabActive = Color3.fromRGB(80, 80, 120),
    tabInactive = Color3.fromRGB(35, 35, 50),
    btnBg = Color3.fromRGB(40, 40, 60),
    btnActive = Color3.fromRGB(0, 100, 0),
    text = Color3.fromRGB(255, 255, 255),
    textDim = Color3.fromRGB(180, 180, 200),
    accent = Color3.fromRGB(100, 100, 255)
}

-- Fungsi bikin pojok melengkung
local function round(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r)
    c.Parent = obj
end

-- ========== ANTI DELETE SYSTEM ==========
local antiDeleteActive = false
local antiDeleteConnections = {}

local function restoreGUI()
    if gui and gui.Parent then return end
    
    local player = game.Players.LocalPlayer
    local playerGui = player:FindFirstChild("PlayerGui")
    
    if gui and not gui.Parent then
        gui.Parent = playerGui
        print("🛡️ GUI restored by Anti-Delete")
    end
end

local function setupAntiDelete()
    if antiDeleteActive then return end
    antiDeleteActive = true
    
    local player = game.Players.LocalPlayer
    local playerGui = player:FindFirstChild("PlayerGui")
    
    if not playerGui then return end
    
    -- Deteksi ketika GUI dihapus
    local descendantRemovingConn = playerGui.DescendantRemoving:Connect(function(descendant)
        if descendant == gui or (gui and descendant:IsDescendantOf(gui)) then
            task.wait(0.05)
            restoreGUI()
        end
    end)
    table.insert(antiDeleteConnections, descendantRemovingConn)
    
    -- Backup tiap beberapa detik
    local backupConn = game:GetService("RunService").Stepped:Connect(function()
        if gui and not gui.Parent then
            restoreGUI()
        end
    end)
    table.insert(antiDeleteConnections, backupConn)
    
    -- Proteksi property
    if gui then
        local function protectGUI()
            pcall(function()
                if gui then
                    gui.ResetOnSpawn = false
                    gui.DisplayOrder = -100
                end
            end)
        end
        
        protectGUI()
        local propertyConn = gui:GetPropertyChangedSignal("ResetOnSpawn"):Connect(protectGUI)
        table.insert(antiDeleteConnections, propertyConn)
    end
end

local function stopAntiDelete()
    if not antiDeleteActive then return end
    antiDeleteActive = false
    
    for _, conn in pairs(antiDeleteConnections) do
        pcall(function() conn:Disconnect() end)
    end
    antiDeleteConnections = {}
end
-- ========== AKHIR ANTI DELETE ==========

-- ========== INIT GUI ==========
function DemoxLib:Init(title)
    if gui then return self end
    
    local player = game.Players.LocalPlayer
    
    -- ScreenGui
    gui = Instance.new("ScreenGui")
    gui.Name = "DemoxGUI"
    gui.Parent = player:WaitForChild("PlayerGui")
    gui.ResetOnSpawn = false
    gui.DisplayOrder = -100  -- Biar di atas GUI lain
    
    -- Frame utama
    mainFrame = Instance.new("Frame")
    mainFrame.Parent = gui
    mainFrame.Size = UDim2.new(0, 400, 0, 450)
    mainFrame.Position = UDim2.new(0.5, -200, 0.5, -225)
    mainFrame.BackgroundColor3 = colors.bg
    mainFrame.BackgroundTransparency = 0.05
    mainFrame.BorderSizePixel = 0
    mainFrame.Visible = false
    round(mainFrame, 12)
    
    -- Header
    local header = Instance.new("TextLabel")
    header.Parent = mainFrame
    header.Size = UDim2.new(1, 0, 0, 40)
    header.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    header.Text = title or "DEMOX MENU ⚡"
    header.TextColor3 = colors.text
    header.TextSize = 18
    header.Font = Enum.Font.GothamBold
    round(header, 12)
    
    -- LEFT PANEL (TEMPAT TAB)
    leftPanel = Instance.new("Frame")
    leftPanel.Parent = mainFrame
    leftPanel.Size = UDim2.new(0, 100, 1, -40)
    leftPanel.Position = UDim2.new(0, 0, 0, 40)
    leftPanel.BackgroundColor3 = colors.left
    leftPanel.BorderSizePixel = 0
    
    -- RIGHT PANEL (TEMPAT KONTEN)
    rightPanel = Instance.new("Frame")
    rightPanel.Parent = mainFrame
    rightPanel.Size = UDim2.new(1, -100, 1, -40)
    rightPanel.Position = UDim2.new(0, 100, 0, 40)
    rightPanel.BackgroundColor3 = colors.bg
    rightPanel.BorderSizePixel = 0
    
    -- SCROLLING FRAME
    scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Parent = rightPanel
    scrollFrame.Size = UDim2.new(1, -10, 1, -10)
    scrollFrame.Position = UDim2.new(0, 5, 0, 5)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.ScrollBarThickness = 4
    
    -- Layout untuk konten
    local layout = Instance.new("UIListLayout")
    layout.Parent = scrollFrame
    layout.Padding = UDim.new(0, 8)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- Update canvas size
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)
    
    -- TOMBOL TOGGLE (pojok kiri bawah)
    toggleBtn = Instance.new("TextButton")
    toggleBtn.Parent = gui
    toggleBtn.Size = UDim2.new(0, 60, 0, 60)
    toggleBtn.Position = UDim2.new(0.5, 435, 0.5, -255)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    toggleBtn.Text = "⚡"
    toggleBtn.TextColor3 = colors.text
    toggleBtn.TextSize = 30
    toggleBtn.Font = Enum.Font.GothamBold
    round(toggleBtn, 30)
    
    toggleBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        mainFrame.Visible = isOpen
        toggleBtn.Text = isOpen and "⚡" or "▶"
        toggleBtn.BackgroundColor3 = isOpen and Color3.fromRGB(35, 35, 55) or Color3.fromRGB(80, 40, 60)
    end)
    
    -- Aktifkan anti delete setelah GUI dibuat
    setupAntiDelete()
    
    return self
end

-- ========== BUAT TAB BARU ==========
function DemoxLib:Tab(name, icon)
    if not leftPanel then
        error("Init dulu bang! Panggil DemoxLib:Init()")
        return {}
    end
    
    -- Bikin tombol tab
    local btn = Instance.new("TextButton")
    btn.Parent = leftPanel
    btn.Size = UDim2.new(1, -10, 0, 40)
    btn.Position = UDim2.new(0, 5, 0, 10 + (#allTabs * 45))
    btn.BackgroundColor3 = colors.tabInactive
    btn.Text = (icon or "📁") .. " " .. name
    btn.TextColor3 = colors.textDim
    btn.TextSize = 13
    btn.Font = Enum.Font.Gotham
    btn.BorderSizePixel = 0
    round(btn, 8)
    
    -- Bikin konten tab (frame kosong)
    local content = Instance.new("Frame")
    content.Parent = scrollFrame
    content.Size = UDim2.new(1, 0, 0, 0)
    content.BackgroundTransparency = 1
    content.Visible = false
    
    local contentLayout = Instance.new("UIListLayout")
    contentLayout.Parent = content
    contentLayout.Padding = UDim.new(0, 8)
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- Simpan data tab
    local tabData = {
        button = btn,
        content = content,
        layout = contentLayout,
        name = name
    }
    table.insert(allTabs, tabData)
    
    -- Fungsi ganti tab
    local function selectTab()
        -- Sembunyiin semua konten
        for _, tab in ipairs(allTabs) do
            tab.content.Visible = false
            tab.button.BackgroundColor3 = colors.tabInactive
            tab.button.TextColor3 = colors.textDim
        end
        -- Tampilin konten yang dipilih
        content.Visible = true
        btn.BackgroundColor3 = colors.tabActive
        btn.TextColor3 = colors.text
        
        -- Update scroll
        task.wait()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, contentLayout.AbsoluteContentSize.Y + 20)
    end
    
    btn.MouseButton1Click:Connect(selectTab)
    
    -- Kalo ini tab pertama, langsung aktifin
    if #allTabs == 1 then
        selectTab()
    end
    
    -- Return methods buat nambahin komponen
    local tabMethods = {}
    
    function tabMethods.AddToggle(self, label, callback)
        local toggle = Instance.new("TextButton")
        toggle.Parent = content
        toggle.Size = UDim2.new(1, -20, 0, 35)
        toggle.BackgroundColor3 = colors.btnBg
        toggle.Text = "🔘 " .. label .. ": OFF"
        toggle.TextColor3 = colors.text
        toggle.TextSize = 13
        toggle.Font = Enum.Font.Gotham
        toggle.BorderSizePixel = 0
        round(toggle, 6)
        
        local state = false
        toggle.MouseButton1Click:Connect(function()
            state = not state
            toggle.Text = state and "🟢 " .. label .. ": ON" or "🔘 " .. label .. ": OFF"
            toggle.BackgroundColor3 = state and colors.btnActive or colors.btnBg
            if callback then callback(state) end
        end)
        
        return toggle
    end
    
    function tabMethods.AddButton(self, label, callback)
        local btn = Instance.new("TextButton")
        btn.Parent = content
        btn.Size = UDim2.new(1, -20, 0, 35)
        btn.BackgroundColor3 = colors.btnBg
        btn.Text = label
        btn.TextColor3 = colors.text
        btn.TextSize = 13
        btn.Font = Enum.Font.Gotham
        btn.BorderSizePixel = 0
        round(btn, 6)
        
        btn.MouseButton1Click:Connect(function()
            if callback then callback() end
        end)
        
        return btn
    end
    
    function tabMethods.AddLabel(self, text, color)
        local label = Instance.new("TextLabel")
        label.Parent = content
        label.Size = UDim2.new(1, -20, 0, 25)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = color or colors.accent
        label.TextSize = 13
        label.Font = Enum.Font.GothamBold
        label.TextXAlignment = Enum.TextXAlignment.Left
        return label
    end
    
    function tabMethods.AddSeparator(self)
        local sep = Instance.new("Frame")
        sep.Parent = content
        sep.Size = UDim2.new(1, -20, 0, 1)
        sep.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
        sep.BorderSizePixel = 0
        return sep
    end
    
    function tabMethods.AddSlider(self, label, minVal, maxVal, defaultVal, callback)
        local frame = Instance.new("Frame")
        frame.Parent = content
        frame.Size = UDim2.new(1, -20, 0, 55)
        frame.BackgroundTransparency = 1
        
        local labelText = Instance.new("TextLabel")
        labelText.Parent = frame
        labelText.Size = UDim2.new(1, 0, 0, 20)
        labelText.BackgroundTransparency = 1
        labelText.Text = label .. ": " .. tostring(defaultVal)
        labelText.TextColor3 = colors.textDim
        labelText.TextSize = 12
        labelText.TextXAlignment = Enum.TextXAlignment.Left
        
        local sliderBg = Instance.new("Frame")
        sliderBg.Parent = frame
        sliderBg.Position = UDim2.new(0, 0, 0, 22)
        sliderBg.Size = UDim2.new(1, 0, 0, 4)
        sliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
        sliderBg.BorderSizePixel = 0
        round(sliderBg, 2)
        
        local fill = Instance.new("Frame")
        fill.Parent = sliderBg
        fill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
        fill.BackgroundColor3 = colors.accent
        fill.BorderSizePixel = 0
        round(fill, 2)
        
        local currentVal = defaultVal
        local dragging = false
        
        local userInput = game:GetService("UserInputService")
        
        local function update(input)
            local percent = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
            currentVal = math.floor(minVal + (maxVal - minVal) * percent)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            labelText.Text = label .. ": " .. tostring(currentVal)
            if callback then callback(currentVal) end
        end
        
        sliderBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                update(input)
            end
        end)
        
        userInput.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                update(input)
            end
        end)
        
        userInput.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
        
        return frame
    end
    
    return tabMethods
end

-- ========== UTILITY FUNCTIONS ==========
function DemoxLib:ToggleGUI()
    if toggleBtn then
        toggleBtn.MouseButton1Click:Fire()
    end
end

function DemoxLib:Close()
    stopAntiDelete()
    if gui then
        gui:Destroy()
        gui = nil
    end
end

function DemoxLib:EnableAntiDelete()
    if gui then
        setupAntiDelete()
    end
end

function DemoxLib:DisableAntiDelete()
    stopAntiDelete()
end

return DemoxLib
